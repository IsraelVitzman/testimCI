# 1. הבסיס: אימג' רשמי של מיקרוסופט שכולל את כל הדפדפנים וספריות הלינוקס
FROM mcr.microsoft.com/playwright:v1.44.0-jammy

# 2. הגדרת תיקיית העבודה בתוך הקונטיינר
WORKDIR /app

# 3. העתקת קבצי ניהול החבילות והתקנתן
# אנחנו עושים את זה לפני העתקת שאר הקוד כדי לנצל את ה-Cache של דוקר
COPY package*.json ./
RUN npm ci

# 4. העתקת כל שאר קבצי הפרויקט (הטסטים, הקונפיג וכו')
COPY . .

# 5. --- התיקון הקריטי עבור OpenShift ---
# אופן-שיפט מריץ קונטיינרים עם משתמש רנדומלי ששייך לקבוצת ה-Root (קבוצה 0).
# הפקודה הזו נותנת לקבוצה 0 הרשאות כתיבה וקריאה לתיקיית האפליקציה.
RUN chgrp -R 0 /app && chmod -R g=u /app

# 6. מעבר למשתמש לא-פריבילגי (למשל 1001)
# זה אומר לאופן-שיפט: "אני לא מנסה להיות Root, אני משתמש רגיל"
USER 1001

# 7. פקודת ברירת המחדל להרצת הטסטים
CMD ["npx", "playwright", "test"]